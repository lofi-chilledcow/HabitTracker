{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "habits-route": {
        "ClusterId": "habits-cluster",
        "Match": {
          "Path": "/api/habits/{**catch-all}"
        }
      },
      "habit-completions-route": {
        "ClusterId": "habit-completions-cluster",
        "Match": {
          "Path": "/api/habit-completions/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5039"
          }
        }
      },
      "habits-cluster": {
        "Destinations": {
          "habits-destination": {
            "Address": "http://localhost:5110"
          }
        }
      },
      "habit-completions-cluster": {
        "Destinations": {
          "habit-completions-destination": {
            "Address": "http://localhost:5225"
          }
        }
      }
    }
  }
}
